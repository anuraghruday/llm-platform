FROM nvcr.io/nvidia/pytorch:24.10-py3

WORKDIR /app

RUN pip install --no-cache-dir vllm==0.6.*

# Copy LoRA adapter checkpoint (built during CI or provided via volume mount)
COPY checkpoints/final/ ./checkpoints/final/

EXPOSE 8001

CMD ["python", "-m", "vllm.entrypoints.openai.api_server", \
     "--model", "mistralai/Mistral-7B-Instruct-v0.3", \
     "--enable-lora", \
     "--lora-modules", "finetuned=./checkpoints/final", \
     "--port", "8001"]
